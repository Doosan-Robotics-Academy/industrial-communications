# ==============================================================================
# Doosan Robotics DRL 예제 - Modbus TCP Slave
# ------------------------------------------------------------------------------
# 로봇 컨트롤러가 Modbus TCP Slave(Server)가 되어, 상위 시스템
# (SCADA, HMI, 상위 PLC)이 로봇의 상태를 읽고 명령을 쓰도록 하는 예제.
#
# [교육용 주의]
#   - Slave 기능 및 함수명(set_modbus_slave_* / server 관련)은 컨트롤러 SW
#     버전에 따라 지원 여부와 시그니처가 다릅니다. 일부 버전은 GPIO/Modbus
#     매핑 방식이 상이하므로 반드시 공식 매뉴얼을 확인 후 사용하세요.
#   - 로봇이 Slave일 때 IP는 로봇 컨트롤러 자신의 IP, Port는 502가 일반적입니다.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1) Slave 레지스터 맵 정의
#    Master(상위)가 접근할 로봇 측 주소 배치
# ------------------------------------------------------------------------------
#   [Holding Register - 상위가 쓰기 / 로봇이 읽기]  명령 채널
ADDR_CMD_MODE     = 0     # 0=대기, 1=홈, 2=작업시작, 9=정지
ADDR_CMD_SPEED    = 1     # 속도 비율(%)

#   [Input Register - 로봇이 쓰기 / 상위가 읽기]     상태 채널
ADDR_STAT_STATE   = 100   # 현재 상태 코드
ADDR_STAT_POSX    = 101   # 현재 TCP X (mm)
ADDR_STAT_CYCLE   = 102   # 완료 사이클 수


# ------------------------------------------------------------------------------
# 2) Slave 서버 초기화
# ------------------------------------------------------------------------------
def setup_modbus_slave():
    tp_log("[ModbusSlave] 슬레이브 서버 초기화")

    # 예시 API: 컨트롤러를 Modbus TCP 서버로 활성화
    #   server_socket_open / set_modbus_slave 계열 함수는 버전별로 다름.
    #   아래는 개념적 표현이며 실제 함수명/인자는 매뉴얼 확인 필요.
    set_modbus_slave_enable(ON, 502)   # 포트 502로 슬레이브 활성화

    # 상태 레지스터 초기값 세팅
    set_modbus_slave_reg(ADDR_STAT_STATE, 0)
    set_modbus_slave_reg(ADDR_STAT_CYCLE, 0)

    tp_log("[ModbusSlave] 초기화 완료 (Port 502)")


# ------------------------------------------------------------------------------
# 3) 상태 갱신 헬퍼 (로봇 -> 상위)
# ------------------------------------------------------------------------------
def publish_state(state_code, cycle):
    set_modbus_slave_reg(ADDR_STAT_STATE, state_code)

    # 현재 TCP 위치 X값을 상태 레지스터로 노출
    cur = get_current_posx()          # posx 반환
    x_mm = DR_ROUND(cur[0])           # 소수부 제거(정수 레지스터)
    set_modbus_slave_reg(ADDR_STAT_POSX, x_mm)

    set_modbus_slave_reg(ADDR_STAT_CYCLE, cycle)
    tp_log("[ModbusSlave] STATE=" + str(state_code) +
           " X=" + str(x_mm) + " CYCLE=" + str(cycle))


# ------------------------------------------------------------------------------
# 4) 명령 폴링 (상위 -> 로봇)
# ------------------------------------------------------------------------------
def read_command():
    mode  = get_modbus_slave_reg(ADDR_CMD_MODE)
    speed = get_modbus_slave_reg(ADDR_CMD_SPEED)
    return mode, speed


# ------------------------------------------------------------------------------
# 5) 메인 루프
#    상위 명령을 폴링하며 상태를 상시 게시하는 서버형 구조
# ------------------------------------------------------------------------------
# 상태 코드 상수
STATE_IDLE  = 0
STATE_HOME  = 1
STATE_RUN   = 2
STATE_STOP  = 9

# 작업 위치 (교육용 예시 좌표)
POS_HOME = posj(0, 0, 90, 0, 90, 0)
POS_WORK = posx(500, 0, 400, 0, 180, 0)

def main():
    setup_modbus_slave()
    cycle = 0

    while True:
        mode, speed = read_command()

        # 속도 비율 적용 (1~100%)
        if speed >= 1 and speed <= 100:
            set_velj(speed)
            set_accj(speed)

        if mode == STATE_HOME:
            publish_state(STATE_HOME, cycle)
            movej(POS_HOME, v=30, a=30)
            set_modbus_slave_reg(ADDR_CMD_MODE, STATE_IDLE)  # 명령 소비

        elif mode == STATE_RUN:
            publish_state(STATE_RUN, cycle)
            movej(POS_HOME, v=60, a=60)
            movel(POS_WORK, v=200, a=200)
            movej(POS_HOME, v=60, a=60)
            cycle = cycle + 1
            set_modbus_slave_reg(ADDR_CMD_MODE, STATE_IDLE)

        elif mode == STATE_STOP:
            publish_state(STATE_STOP, cycle)
            tp_log("[ModbusSlave] 정지 명령 수신 - 루프 종료")
            break

        else:
            publish_state(STATE_IDLE, cycle)

        wait(0.1)   # 폴링 주기

    set_modbus_slave_enable(OFF, 502)


main()
